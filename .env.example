# Hinata AI Agent — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------ LLM Provider ------
# Options: "ollama" (local, free) | "openai" | "gemini"
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# Ollama (install from https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional — get key from https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (optional — get key from https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ------ Voice ------
VOICE_ENABLED=true
STT_ENGINE=google
TTS_ENGINE=edge
TTS_VOICE=en-US-AriaNeural

# ------ Search ------
# DuckDuckGo is free and works without an API key
SEARCH_PROVIDER=duckduckgo
# Optional: SerpAPI key (https://serpapi.com) or Tavily key (https://tavily.com)
SEARCH_API_KEY=

# ------ Weather ------
# Optional: OpenWeatherMap API key (https://openweathermap.org/api)
# Without it, Hinata uses wttr.in (free, no key needed)
WEATHER_API_KEY=

# ------ System ------
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-string
API_HOST=0.0.0.0
API_PORT=8000
